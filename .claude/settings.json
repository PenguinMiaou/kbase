{
  "hooks": {
    "PreCommit": [
      {
        "type": "command",
        "command": "cd /Users/briantiong/Desktop/kbase && ruff check kbase/ tests/ --quiet"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(make lint)",
