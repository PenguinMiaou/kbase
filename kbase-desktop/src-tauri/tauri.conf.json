{
  "$schema": "https://raw.githubusercontent.com/nickkadutskyi/tauri-schema/refs/heads/v2/schema.json",
  "productName": "KBase",
  "version": "0.7.0",
  "identifier": "com.penguinmiaou.kbase",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "KBase",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "KBase"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "localhost"
    },
    "resources": [
      "scripts/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
